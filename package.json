{
  "name": "hsmkit",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Professional online encryption toolkit with 44+ cryptographic tools for HSM key management, payment security, PKI certificates, and more.",
  "repository": {
    "type": "git",
    "url": "https://github.com/anomalyco/hsmkit"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prebuild": "node scripts/update-sitemap-lastmod.js && npx puppeteer browsers install chrome",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "antd": "^6.1.0",
    "base-x": "^5.0.1",
    "crypto-js": "^4.2.0",
    "elliptic": "^6.6.1",
    "hash-wasm": "^4.12.0",
    "i18next": "^26.3.0",
    "iconv-lite": "^0.7.0",
    "node-forge": "^1.3.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.11.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@prerenderer/renderer-puppeteer": "^1.2.4",
    "@prerenderer/rollup-plugin": "^0.3.12",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/crypto-js": "^4.2.2",
    "@types/elliptic": "^6.4.18",
    "@types/node": "^24.10.1",
    "@types/node-forge": "^1.3.14",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^29.1.1",
    "puppeteer": "^24.35.0",
    "sharp": "^0.34.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "npm:rolldown-vite@7.2.5",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.7"
  },
  "overrides": {
    "vite": "npm:rolldown-vite@7.2.5"
  }
}
